# GitHub App (https://github.com/settings/apps)
APP_ID=
WEBHOOK_SECRET=
# PEM contents as a single line, or path via PRIVATE_KEY_PATH
PRIVATE_KEY=
PRIVATE_KEY_PATH=

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://mergegraph:mergegraph@localhost:5432/mergegraph

# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# Local webhook forwarding (https://smee.io)
# smee -u $SMEE_URL -t http://localhost:3000/api/webhook
SMEE_URL=