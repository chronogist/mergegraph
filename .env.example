# ── Always required ──────────────────────────────────────────
DATABASE_URL=postgresql://mergegraph:mergegraph@localhost:5432/mergegraph
WEBHOOK_SECRET=

# ── Phase 1+ (GitHub API: fetch PRs, post @mergegraph replies) ──
# Phase 0 webhook testing works without these.
APP_ID=
PRIVATE_KEY_PATH=

# ── Phase 1+ (0G Compute: extraction + Q&A + embeddings) ─────
OG_COMPUTE_ROUTER_URL=https://router-api.0g.ai/v1
OG_COMPUTE_ROUTER_API_KEY=
OG_CHAT_MODEL=gpt-4o-mini
OG_EMBEDDING_MODEL=text-embedding-3-small

# ── Phase 1+ (0G Storage: Memory Capsules) ───────────────────
# Set SKIP_0G_STORAGE=true to store capsules in Postgres only (local dev).
SKIP_0G_STORAGE=true
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ── Local webhook forwarding (https://smee.io) ───────────────
SMEE_URL=