# ── Minimum local test (2 values + mock mode) ─────────────────
DATABASE_URL=postgresql://mergegraph:mergegraph@localhost:5432/mergegraph
WEBHOOK_SECRET=any-secret-you-choose-for-local-testing
DEV_MOCK=true
SKIP_0G_STORAGE=true

# ── Production (MergeGraph operator only — NOT repo users) ───
# Set these in your hosting dashboard (Render/Fly/etc), not in git.
# APP_ID=
# PRIVATE_KEY_PATH=
# OG_COMPUTE_ROUTER_API_KEY=

# ── Optional overrides ───────────────────────────────────────
# NODE_ENV=development
# PORT=3000
# HOST=localhost
# OG_COMPUTE_ROUTER_URL=https://router-api.0g.ai/v1
# OG_CHAT_MODEL=gpt-4o-mini
# OG_EMBEDDING_MODEL=text-embedding-3-small
# SMEE_URL=https://smee.io/YOUR_CHANNEL