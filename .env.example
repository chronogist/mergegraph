# ── Required (server operator) ───────────────────────────────
DATABASE_URL=postgresql://mergegraph:mergegraph@localhost:5432/mergegraph
WEBHOOK_SECRET=

# GitHub App — your server acts AS the app (see docs/GITHUB_APP.md)
APP_ID=
PRIVATE_KEY_PATH=

# 0G Compute Router — extraction + Q&A (chat)
OG_COMPUTE_ROUTER_URL=https://router-api.0g.ai/v1
OG_COMPUTE_ROUTER_API_KEY=
OG_CHAT_MODEL=glm-5.1

# OpenRouter — embeddings only (0G Router has no /embeddings endpoint)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# 0G Storage — set SKIP_0G_STORAGE=true to skip wallet during dev
SKIP_0G_STORAGE=true
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=

# ── Phase 2 ──────────────────────────────────────────────────
MERGE_SUMMARY_COMMENT=false
BACKFILL_PR_LIMIT=200
BACKFILL_ISSUE_LIMIT=100

# Landing page (apps/web / Vercel) — GitHub App public slug from app settings
NEXT_PUBLIC_GITHUB_APP_SLUG=mergegraph

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ── Web app (apps/web) ───────────────────────────────────────
# Optional: override install URL entirely
# NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/mergegraph/installations/new

# ── Local webhook forwarding (https://smee.io) ───────────────
SMEE_URL=