{
  "name": "mergegraph",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @mergegraph/api",
    "build": "npm run build -w @mergegraph/db && npm run build -w @mergegraph/api",
    "db:generate": "npm run generate -w @mergegraph/db",
    "db:migrate": "npm run migrate -w @mergegraph/db",
    "db:studio": "npm run studio -w @mergegraph/db"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}